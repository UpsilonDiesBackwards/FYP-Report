@book{steinhauserComputerSimulationPhysics2012,
  title = {Computer {{Simulation}} in {{Physics}} and {{Engineering}}},
  author = {Steinhauser, Martin Oliver},
  date = {2012},
  publisher = {De Gruyter, Inc.},
  location = {Berlin/Boston, GERMANY},
  url = {http://ebookcentral.proquest.com/lib/portsmouth-ebooks/detail.action?docID=893213},
  urldate = {2026-03-04},
  abstract = {This work is a needed reference for widely used techniques and methods of computer simulation in physics and other disciplines, such as materials science. Molecular dynamics computes a molecule's reactions and dynamics based on physical models; Monte Carlo uses random numbers to image a system's behaviour when there are different possible outcomes with related probabilities. The work conveys both the theoretical foundations as well as applications and "tricks of the trade", that often are scattered across various papers. Thus it will meet a need and fill a gap for every scientist who needs computer simulations for his/her task at hand. In addition to being a reference, case studies and exercises for use as course reading are included.},
  isbn = {978-3-11-025606-2},
  keywords = {Engineering -- Computer simulation.,Engineering -- Data processing.,Physics -- Computer simulation.,Physics -- Data processing.}
}

@article{huhnDifferentiableSimulationsParticle2025,
  title = {Differentiable Simulations for Particle Tracking in Accelerators: {{Analysis}}, Benchmarking, and Optimization},
  shorttitle = {Differentiable Simulations for Particle Tracking in Accelerators},
  author = {Huhn, Francisco and Velotti, Francesco M.},
  date = {2025-11-01},
  journaltitle = {Physical Review Accelerators and Beams},
  volume = {28},
  number = {11},
  pages = {114603--114603},
  publisher = {American Physical Society},
  issn = {24699888},
  doi = {10.1103/cbds-lst1},
  abstract = {Optimization of beamlines and lattices is a common problem in accelerator physics, which is usually solved with semianalytical methods and numerical optimization routines. However, these are usually of the gradient-free or finite-difference type, whose computational cost grows quickly with the number of optimization parameters. On the other hand, the cost of gradient-based optimization can scale well with the number of parameters, but only if the computation of the gradient is itself efficient (e.g., not via finite differences, which are inefficient). Recently, there has been an emergence of so-called “differentiable” codes that efficiently provide gradients. Nevertheless, analysis and benchmarking comparisons of these techniques have largely been absent from the literature. In this work, we develop our own differentiable code via autodifferentiation. We analyze and benchmark differentiability against finite differences in two test cases, a space-charge FODO cell from the literature and a realistic future beamline at CERN. The analyses and benchmarking are done both theoretically and empirically. Finally, we embed the gradient provided by the differentiable code in gradient-based optimization routines and compare with gradient-free methods. This work offers the first such analysis and benchmarking and thus contributes toward the development of more efficient and performant particle accelerators.},
  langid = {english},
  keywords = {Nuclear and particle physics. Atomic energy. Radioactivity,QC770-798},
  file = {/Users/tayler/Zotero/storage/MJD3T6G7/Huhn and Velotti - 2025 - Differentiable simulations for particle tracking in accelerators Analysis, benchmarking, and optimi.pdf}
}

