@article{xuParticleSimulationStudy2024,
  title = {Particle Simulation Study on the Transport of Laser-Accelerated Proton Beams in High-Density Plasmas},
  author = {Xu, W. W. and Hu, Z. H. and Zhao, Y. T. and Wang, Y. N.},
  date = {2024-06-16},
  journaltitle = {2024 IEEE International Conference on Plasma Science (ICOPS), Plasma Science (ICOPS), 2024 IEEE International Conference on},
  pages = {1--1},
  publisher = {IEEE},
  issn = {979-8-3503-6091-2},
  doi = {10.1109/ICOPS58192.2024.10626678},
  url = {https://research.ebsco.com/linkprocessor/plink?id=f015f43a-4588-3546-991c-64b37817d1c2},
  urldate = {2026-04-17},
  abstract = {Ion beam has important applications in inertial confinement fusion and high energy density physics. In this work, we used EPOCH (Extendable PIC Open Collaboration) to simulate the transport of laser-accelerated proton beams in high density plasmas with different ion charge numbers. Especially in the plasma with a high ion charge number, where the plasma collision frequency approaches electron oscillation frequency, the beam protons are strongly decelerated by the electric field induced by plasma return current. The energy deposition is further enhanced as the beam travel distance increases due to beam density selfsteeping, which is also confirmed by three-dimensional simulation. Interestingly, in the transverse direction, we observed that proton beams evolved into multiple current filaments due to current filamentation instability (CFI). Following that, we found through two-dimensional transverse simulations that Coulomb collisions can accelerate the merging process of current filaments. We preliminarily attribute this to Coulomb collisions causing plasma heating, thereby accelerating the nonlinear process of CFI.},
  keywords = {Inertial confinement,Ions,Laser beams,Merging,Nuclear Engineering,Particle beams,Plasmas,Protons}
}

